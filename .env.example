PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/hillspace
FRONTEND_URL=http://localhost:3000
# Public API origin used in email links (include host only; /api is added automatically)
# On Render this falls back to RENDER_EXTERNAL_URL if unset.
# BACKEND_URL=https://hillspace-backend.onrender.com
# EMAIL_LOGO_URL=https://res.cloudinary.com/your-cloud/image/upload/hillspace/email-logo.png

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hillspace

# Email — Gmail OAuth2 only (Gmail API via googleapis; no SMTP)
# Obtain a refresh token via Google OAuth Playground with Gmail send scope.
# Skip startup OAuth verify: EMAIL_VERIFY_ON_BOOT=false
GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxx
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=1//0g...
GMAIL_USER=youraccount@gmail.com
GMAIL_FROM=HillSpace <youraccount@gmail.com>
